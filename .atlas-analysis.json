  "keyFeatures": [
    "Provider-agnostic agent run lifecycle with structured checkpointing and resume",
    "Default-deny policy engine with approval workflows, audit events, and redaction",
    "Policy-gated tool registry supporting function tools and trusted MCP fixtures",
    "Replaceable BYO module ports for memory, context, search, store, provider, and observability",
    "Deterministic local provider for dev and testing without external API calls",
    "Evidence packets tying every generated artifact to its source, command, and freshness class",
    "Agent-first CLI (`jami`) for init, run, resume, approve, inspect, doctor, and verify",
    "JSON Schema contract anchors shared across harness and Studio UI boundaries",
    "Local workbench static shell for runtime evidence and system map inspection",
    "Docs pipeline that generates quickstart, user manual, system map, and changelog from source"
  ],
  "publicApiSurface": [
    "createHarness() — @jami-studio/harness-sdk",
    "harness.run({ runId, providerId, sourceRepo, sourceCommit, sourceRef })",
    "harness.resume({ runId })",
    "harness.approve({ runId, actionId })",
    "harness.deny({ runId, actionId })",
    "harness.inspect()",
    "createFileSystemCheckpointStore() — @jami-studio/harness-store-local",
    "createDefaultPolicyEngine(options) — @jami-studio/harness-policy",
    "evaluate(request) — policy engine port",
    "listToolAdapterCapabilities() — @jami-studio/harness-tools",
    "listToolAdapterSourceLocks() — @jami-studio/harness-tools",
    "dryRunUnsupportedAdapter() — @jami-studio/harness-tools",
    "artifactRecord creation — @jami-studio/harness-artifacts",
    "jami init --json",
    "jami run --json",
    "jami resume --json --run-id <runId>",
    "jami approve --json --run-id <runId> --action-id <actionId>",
    "jami deny --json --run-id <runId> --action-id <actionId>",
    "jami inspect --json",
    "jami doctor --json",
    "jami tools --json",
    "jami map --json",
    "jami verify --json",
    "jami workbench --json",
    "Contract schemas: runEvent, toolExecution, policyDecision, artifactRecord, evidencePacket, actionRef, approvalRequest, auditEvent, secretRef, memoryRecord, contextPack, capabilityManifest"
  ]
}
